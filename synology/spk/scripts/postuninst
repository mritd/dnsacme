#!/bin/sh

# DSM intentionally preserves the package FHS var, etc, and home directories
# after uninstall. Remove their contents on a real uninstall so certificates,
# ACME account keys, configuration, and logs are not left behind. During an
# upgrade DSM invokes this script with UPGRADE, and all persistent data must stay.
if [ "$SYNOPKG_PKG_STATUS" = "UNINSTALL" ]; then
  for dir in \
    /var/packages/dnsacme/var \
    /var/packages/dnsacme/etc \
    /var/packages/dnsacme/home
  do
    [ -d "$dir" ] || continue
    # Include hidden entries without relying on non-POSIX find extensions.
    rm -rf "$dir"/* "$dir"/.[!.]* "$dir"/..?*
  done
fi

exit 0
