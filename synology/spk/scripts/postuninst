#!/bin/sh
# Best-effort removal of the published notification catalog on a real uninstall
# only (not an upgrade, where SYNOPKG_PKG_STATUS=UPGRADE and the catalog is still
# valid). DSM runs this script as the unprivileged package user in a sandbox, so
# it usually cannot remove the root-owned catalog; a user who wants it gone first
# runs `... synology publish-notifications --disable` as root. The rm stays as a
# harmless best-effort for the case where privileges do allow it.
if [ "$SYNOPKG_PKG_STATUS" != "UPGRADE" ]; then
  rm -rf /var/cache/texts/DNSACME
fi
exit 0
