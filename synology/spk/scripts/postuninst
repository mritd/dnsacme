#!/bin/sh

# DSM intentionally preserves the package FHS var, etc, and home directories
# after uninstall. Keep them by default so a later installation can reuse the
# existing state. Remove their contents only when the uninstall wizard explicitly
# requests deletion. During an upgrade DSM invokes this script with UPGRADE, and
# all persistent data must stay.
if [ "${SYNOPKG_PKG_STATUS:-}" = "UNINSTALL" ] && \
   [ "${wizard_delete_data:-false}" = "true" ]; then
  for dir in \
    /var/packages/dnsacme/var \
    /var/packages/dnsacme/etc \
    /var/packages/dnsacme/home
  do
    [ -d "$dir" ] || continue
    # Include hidden entries without relying on non-POSIX find extensions.
    rm -rf "$dir"/* "$dir"/.[!.]* "$dir"/..?*
  done
fi

exit 0
